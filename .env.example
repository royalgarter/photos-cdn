# ARANGO_URL: Connection URL to the ArangoDB instance (e.g. https://root:password@localhost:8529/database)
ARANGO_URL=

# Note: All other configurations (such as GEMINI_API_KEY, REPLICATE_API_TOKEN, R2_ACCESS_KEY_ID, R2_SECRET_ACCESS_KEY, R2_BUCKET_NAME, R2_ENDPOINT) are stored inside the ArangoDB 'Settings' collection.

# Optional bootstrap env vars (overridden by Settings collection):
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
WALLHAVEN_API_KEY=
OPENVERSE_CLIENT_ID=
OPENVERSE_CLIENT_SECRET=

# Ops alert webhook — POST JSON {text} on embedding failures (Slack/Discord/ntfy)
ALERT_WEBHOOK_URL=
